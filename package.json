{
  "type": "module",
  "name": "@satisfactory-dev/slugify",
  "description": "nodejs template",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/satisfactory-dev/Slugify.git"
  },
  "funding": "https://github.com/satisfactory-dev/Slugify?sponsor=1",
  "keywords": [
    "slugify",
    "slug",
    "string",
    "url",
    "cocur/slugify",
    "php",
    "php-parser"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "src/**/*.js",
    "!src/types.js",
    "src/**/*.d.ts",
    "generated-src/**/*.js",
    "generated-src/**/*.d.ts"
  ],
  "devDependencies": {
    "@signpostmarv/oxlint-config": "^0.3.1",
    "@types/node": "^25.7.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1",
    "php-parser": "^3.2.5",
    "prettier": "^3.5.3",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@types/regexp.escape": "^2.0.0",
    "locutus": "^2.0.32"
  }
}
